{
    "compilerOptions": {
        "sourceMap": true,
        "allowSyntheticDefaultImports": true,
        "module": "NodeNext",
        "outDir": "./static/gen-js",
        "rootDir": "./static/js",
        "strict": true,
        "target": "es6",
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": [
        "./static/js/*"
    ]
}
